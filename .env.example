# ───────────────────────────────────────────────────────────────
# NPO Tamil Lecture Platform — environment variables
# Copy to `.env` for local dev. Set the same keys in Vercel for prod.
# ───────────────────────────────────────────────────────────────

# Neon Postgres (Free Tier).
# DATABASE_URL  -> pooled connection (used by the app at runtime).
# DIRECT_URL    -> direct connection (used by `prisma migrate`).
# Get both from the Neon dashboard → Connection Details.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/neondb?sslmode=require"

# Auth.js (NextAuth v5).
# AUTH_SECRET: generate with `npx auth secret` or `openssl rand -base64 32`.
AUTH_SECRET="replace-with-a-long-random-string"

# Google OAuth credentials (Google Cloud Console → APIs & Services → Credentials).
# Authorized redirect URI (prod):  https://your-domain.vercel.app/api/auth/callback/google
# Authorized redirect URI (local): http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID="xxxxxxxx.apps.googleusercontent.com"
AUTH_GOOGLE_SECRET="xxxxxxxx"

# Public site URL (used for canonical links / redirects).
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Comma-separated list of emails that should be granted ADMIN on first login.
# Everyone else becomes a MEMBER automatically.
ADMIN_EMAILS="founder@example.org"
